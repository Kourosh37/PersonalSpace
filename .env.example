APP_NAME=Space
PUBLIC_BASE_URL=http://localhost

POSTGRES_DB=space
POSTGRES_USER=space
POSTGRES_PASSWORD=space
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_ADDR=redis:6379

BACKEND_HTTP_ADDR=:8080
BACKEND_SESSION_COOKIE_NAME=space_session
BACKEND_SESSION_TTL_HOURS=168
BACKEND_SESSION_SECURE=false
BACKEND_SESSION_SAME_SITE=lax
BACKEND_ENFORCE_SECURE_COOKIES=true
BACKEND_CSRF_DISABLED=false
BACKEND_ALLOWED_ORIGINS=http://localhost
BACKEND_STORAGE_ROOT=/data/storage
SECURITY_LOGIN_RATE_LIMIT_PER_MINUTE=15
SECURITY_SHARE_PASSWORD_RATE_LIMIT_PER_MINUTE=20
SECURITY_UPLOAD_INIT_RATE_LIMIT_PER_MINUTE=60
SECURITY_UPLOAD_COMPLETE_RATE_LIMIT_PER_MINUTE=60
SECURITY_TUS_CREATE_RATE_LIMIT_PER_MINUTE=60
SECURITY_PREVIEW_JOB_RATE_LIMIT_PER_MINUTE=30
SECURITY_ZIP_DOWNLOAD_RATE_LIMIT_PER_MINUTE=20
PREVIEW_WORKER_POLL_INTERVAL_SECONDS=3
PREVIEW_WORKER_MAX_ATTEMPTS=3

SPACE_APP_PORT=3000
